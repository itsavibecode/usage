rules_version = '2';

// Usage Tracker — Firestore security rules
// Per-user isolation: each signed-in user can only read/write documents
// under their own /users/{uid} subtree. Nothing else is accessible.
//
// To apply: Firebase Console → Firestore Database → Rules tab → paste this
// entire file → Publish.

service cloud.firestore {
  match /databases/{database}/documents {

    // Everything a user owns lives under /users/{uid}/...
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Deny everything else by default (no unauthenticated access,
    // no cross-user access).
  }
}
